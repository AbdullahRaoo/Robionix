# Copy to deploy/.env on the server and fill in real values (this file is a template).
# deploy/.env is gitignored and must never be committed.

# Resend API key for the contact form (/api/contact). Until a real key is set,
# form submissions will fail to send email but the site otherwise works.
RESEND_API_KEY=re_sample_replace_me_with_real_key

# Where contact-form submissions are emailed.
CONTACT_TO=awaisfrombit@gmail.com
